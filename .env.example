# Environment variables for EMAT Celulosa CRM
# Copy this file to .env.local and fill in your values

VITE_APP_BASE_URL=http://localhost:5173

# Supabase Configuration
# Get these values from: Supabase Dashboard → Settings → API
# Auth: crear usuarios en Dashboard (Authentication → Users), no en este archivo.
# Ver scripts/setup-auth-user.md para el usuario comercial inicial.

# Project URL — Settings → API → Project URL
VITE_SUPABASE_URL=https://ywbgeqjqjfnhldqqqklj.supabase.co

# Anon (public) key — Settings → API → Project API keys → anon public
VITE_SUPABASE_ANON_KEY=sb_publishable_tTjxPIfD_RqADONQwLdJTg_8Xj6iPJx

# (Opcional) Email de superusuario legacy con acceso ADMIN sin pasar por la tabla usuario.
# Dejá vacío o eliminá esta línea para deshabilitar el bypass en nuevos proyectos.
# En producción: configurar en Vercel → Settings → Environment Variables.
# VITE_ADMIN_BYPASS_EMAIL=admin@tudominio.com
